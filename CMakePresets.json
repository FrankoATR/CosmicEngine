{
  "version": 6,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 23,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "base",
      "hidden": true,
      "binaryDir": "${sourceDir}/build/${hostSystemName}/${presetName}",
      "cacheVariables": {
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
      }
    },
    {
      "name": "windows-base",
      "hidden": true,
      "inherits": ["base"],
      "generator": "MinGW Makefiles",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      }
    },
    {
      "name": "linux-base",
      "hidden": true,
      "inherits": ["base"],
      "generator": "Unix Makefiles",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Linux"
      }
    },
    {
      "name": "windows-sandbox-3d-debug",
      "inherits": ["windows-base"],
      "displayName": "Windows sandbox_3D Debug",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "COSMIC_PROJECT": "sandbox_3D"
      }
    },
    {
      "name": "windows-sandbox-3d-release",
      "inherits": ["windows-base"],
      "displayName": "Windows sandbox_3D Release",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "COSMIC_PROJECT": "sandbox_3D"
      }
    },
    {
      "name": "windows-basicdemo-2d-debug",
