{
  "version": 6,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 23,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "base",
      "hidden": true,
      "cacheVariables": {
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
      }
    },
    {
      "name": "windows-base",
      "hidden": true,
      "inherits": ["base"],
      "generator": "MinGW Makefiles",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      }
    },
    {
      "name": "linux-base",
      "hidden": true,
      "inherits": ["base"],
      "generator": "Unix Makefiles",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Linux"
      }
    },
    {
      "name": "windows-debug-base",
      "hidden": true,
      "inherits": ["windows-base"],
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "windows-release-base",
      "hidden": true,
      "inherits": ["windows-base"],
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    },
    {
      "name": "linux-debug-base",
      "hidden": true,
      "inherits": ["linux-base"],
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "linux-release-base",
      "hidden": true,
      "inherits": ["linux-base"],
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    },
    {
      "name": "windows-debug-networkdemo",
      "displayName": "Windows Debug - NetworkDemo",
      "inherits": ["windows-debug-base"],
      "binaryDir": "${sourceDir}/build/Windows/networkdemo-debug",
      "cacheVariables": {
        "COSMIC_PROJECT": "NetworkDemo"
      }
    },
    {
      "name": "windows-debug-basicdemo-2d",
      "displayName": "Windows Debug - BasicDemo_2D",
      "inherits": ["windows-debug-base"],
      "binaryDir": "${sourceDir}/build/Windows/basicdemo-2d-debug",
      "cacheVariables": {
        "COSMIC_PROJECT": "BasicDemo_2D"
      }
    },
    {
      "name": "windows-debug-basicdemo-3d",
      "displayName": "Windows Debug - BasicDemo_3D",
      "inherits": ["windows-debug-base"],
      "binaryDir": "${sourceDir}/build/Windows/basicdemo-3d-debug",
      "cacheVariables": {
        "COSMIC_PROJECT": "BasicDemo_3D"
      }
    },
    {
      "name": "windows-debug-sandbox-3d",
      "displayName": "Windows Debug - sandbox_3D",
      "inherits": ["windows-debug-base"],
      "binaryDir": "${sourceDir}/build/Windows/sandbox-3d-debug",
      "cacheVariables": {
        "COSMIC_PROJECT": "sandbox_3D"
      }
    },
    {
      "name": "windows-release-networkdemo",
      "displayName": "Windows Release - NetworkDemo",
      "inherits": ["windows-release-base"],
      "binaryDir": "${sourceDir}/build/Windows/networkdemo-release",
      "cacheVariables": {
        "COSMIC_PROJECT": "NetworkDemo"
      }
    },
    {
      "name": "windows-release-basicdemo-2d",
      "displayName": "Windows Release - BasicDemo_2D",
      "inherits": ["windows-release-base"],
      "binaryDir": "${sourceDir}/build/Windows/basicdemo-2d-release",
      "cacheVariables": {
        "COSMIC_PROJECT": "BasicDemo_2D"
      }
    },
    {
      "name": "windows-release-basicdemo-3d",
      "displayName": "Windows Release - BasicDemo_3D",
      "inherits": ["windows-release-base"],
      "binaryDir": "${sourceDir}/build/Windows/basicdemo-3d-release",
      "cacheVariables": {
        "COSMIC_PROJECT": "BasicDemo_3D"
      }
    },
    {
      "name": "windows-release-sandbox-3d",
      "displayName": "Windows Release - sandbox_3D",
      "inherits": ["windows-release-base"],
      "binaryDir": "${sourceDir}/build/Windows/sandbox-3d-release",
      "cacheVariables": {
        "COSMIC_PROJECT": "sandbox_3D"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "build-windows-debug-networkdemo",
      "configurePreset": "windows-debug-networkdemo"
    },
    {
      "name": "build-windows-debug-basicdemo-2d",
      "configurePreset": "windows-debug-basicdemo-2d"
    },
    {
      "name": "build-windows-debug-basicdemo-3d",
      "configurePreset": "windows-debug-basicdemo-3d"
    },
    {
      "name": "build-windows-debug-sandbox-3d",
      "configurePreset": "windows-debug-sandbox-3d"
    },
    {
      "name": "build-windows-release-networkdemo",
      "configurePreset": "windows-release-networkdemo"
    },
    {
      "name": "build-windows-release-basicdemo-2d",
      "configurePreset": "windows-release-basicdemo-2d"
    },
    {
      "name": "build-windows-release-basicdemo-3d",
      "configurePreset": "windows-release-basicdemo-3d"
    },
    {
      "name": "build-windows-release-sandbox-3d",
      "configurePreset": "windows-release-sandbox-3d"
    }
  ]
}