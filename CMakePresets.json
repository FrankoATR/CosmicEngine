{
  "version": 6,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 23,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "base",
      "hidden": true,
      "cacheVariables": {
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
      }
    },
    {
      "name": "windows-base",
      "hidden": true,
      "inherits": ["base"],
      "generator": "MinGW Makefiles",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      }
    },
    {
      "name": "linux-base",
      "hidden": true,
      "inherits": ["base"],
      "generator": "Unix Makefiles",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Linux"
      }
    },
    {
      "name": "windows-debug-base",
      "hidden": true,
      "inherits": ["windows-base"],
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "windows-release-base",
      "hidden": true,
      "inherits": ["windows-base"],
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    },
    {
      "name": "linux-debug-base",
      "hidden": true,
      "inherits": ["linux-base"],
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "linux-release-base",
      "hidden": true,
      "inherits": ["linux-base"],
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    },
    {
      "name": "windows-debug-puzzlerpg",
      "displayName": "Windows Debug - PuzzleRPG",
      "inherits": ["windows-debug-base"],
      "binaryDir": "${sourceDir}/build/Windows/puzzlerpg-debug",
      "cacheVariables": {
        "COSMIC_PROJECT": "PuzzleRPG",
        "COSMIC_PROJECT_PROGRAM_ICON_PATH": "assets/textures/icon/icon.ico"
      }
    },
    {
      "name": "windows-release-puzzlerpg",
      "displayName": "Windows Release - PuzzleRPG",
      "inherits": ["windows-release-base"],
      "binaryDir": "${sourceDir}/build/Windows/puzzlerpg-release",
      "cacheVariables": {
        "COSMIC_PROJECT": "PuzzleRPG",
        "COSMIC_PROJECT_PROGRAM_ICON_PATH": "assets/textures/icon/icon.ico"
      }
    },
    {
      "name": "linux-debug-puzzlerpg",
      "displayName": "Linux Debug - PuzzleRPG",
      "inherits": ["linux-debug-base"],
      "binaryDir": "${sourceDir}/build/Linux/puzzlerpg-debug",
      "cacheVariables": {
        "COSMIC_PROJECT": "PuzzleRPG",
        "COSMIC_PROJECT_PROGRAM_ICON_PATH": "assets/textures/icon/icon.ico"
      }
    },
    {
      "name": "linux-release-puzzlerpg",
      "displayName": "Linux Release - PuzzleRPG",
      "inherits": ["linux-release-base"],
      "binaryDir": "${sourceDir}/build/Linux/puzzlerpg-release",
      "cacheVariables": {
        "COSMIC_PROJECT": "PuzzleRPG",
        "COSMIC_PROJECT_PROGRAM_ICON_PATH": "assets/textures/icon/icon.ico"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "build-windows-debug-puzzlerpg",
      "configurePreset": "windows-debug-puzzlerpg"
    },
    {
      "name": "build-windows-release-puzzlerpg",
      "configurePreset": "windows-release-puzzlerpg"
    },
    {
      "name": "build-linux-debug-puzzlerpg",
      "configurePreset": "linux-debug-puzzlerpg"
    },
    {
      "name": "build-linux-release-puzzlerpg",
      "configurePreset": "linux-release-puzzlerpg"
    }
  ]
}