# ---- Vendored dependencies required by CMake ----
# This project links directly against these vendored files, so they must remain trackable.
!lib/
lib/*
!lib/glad/
lib/glad/*
!lib/glad/src/
!lib/glad/src/glad.c
!lib/libglfw3.a
