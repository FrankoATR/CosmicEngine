PROJECT_NAME           = "CosmicEngine"
PROJECT_BRIEF          = "Technical API documentation for the CosmicEngine multi-project framework"
OUTPUT_DIRECTORY       = docs/doxygen
CREATE_SUBDIRS         = NO
ALLOW_UNICODE_NAMES    = YES
OUTPUT_LANGUAGE        = English
BRIEF_MEMBER_DESC      = YES
REPEAT_BRIEF           = NO
ALWAYS_DETAILED_SEC    = NO
FULL_PATH_NAMES        = NO
STRIP_FROM_PATH        = .
JAVADOC_AUTOBRIEF      = YES
MULTILINE_CPP_IS_BRIEF = NO
INHERIT_DOCS           = YES
MARKDOWN_SUPPORT       = YES
AUTOLINK_SUPPORT       = YES
INPUT_ENCODING         = UTF-8
GENERATE_HTML          = YES
GENERATE_XML           = YES
GENERATE_LATEX         = NO
EXTRACT_ALL            = YES
EXTRACT_PRIVATE        = NO
EXTRACT_STATIC         = YES
SHOW_INCLUDE_FILES     = YES
INLINE_INFO            = YES
SORT_MEMBER_DOCS       = YES
SORT_BRIEF_DOCS        = YES
WARNINGS               = YES
WARN_IF_UNDOCUMENTED   = YES
WARN_IF_DOC_ERROR      = YES
WARN_NO_PARAMDOC       = YES
QUIET                  = NO
INPUT                  = include/CosmicEngine docs/mainpage.dox
FILE_PATTERNS          = *.hpp *.cpp *.h *.c
RECURSIVE              = YES
EXCLUDE                =
USE_MDFILE_AS_MAINPAGE =
FILE_PATTERNS         += *.dox